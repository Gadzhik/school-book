    "@reader/adapters": "workspace:*",
    "@reader/book-scanner": "workspace:*",
    "@reader/converters": "workspace:*",
    "@reader/network": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "svelte": "^5.16.0",
    "typescript": "^5.7.2"
  }
}
