{
  "name": "@reader/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Общие Svelte-компоненты читалки и настроек, темы, сторы состояния",
  "type": "module",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
